# Copy to .env and fill in values
# On Railway: add these as environment variables in the project dashboard

# ── Market Data ───────────────────────────────────────────────────
# Finnhub (free tier: 60 req/min) — required for quotes, candles, earnings
FINNHUB_API_KEY=your_finnhub_key_here

# Polygon.io (paid, for future real-time upgrade)
# POLYGON_API_KEY=your_polygon_key_here

# ── News ──────────────────────────────────────────────────────────
# Alpaca (free, gives access to Benzinga news feed)
ALPACA_API_KEY=your_alpaca_key_here
ALPACA_API_SECRET=your_alpaca_secret_here

# Financial Modeling Prep (free: 250 req/day, good SEC/earnings coverage)
FMP_API_KEY=your_fmp_key_here

# ── Social / Sentiment ────────────────────────────────────────────
# Reddit (public API, no key needed — just set a descriptive user-agent)
REDDIT_USER_AGENT=RocketNews/0.1

# ── AI (Airlock) ──────────────────────────────────────────────────
# Backend uses Claude Haiku for news/sentiment airlock scoring only.
# AI Chat in the frontend uses the user's own Gemini key (browser-only).
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── Telegram Alerts (optional) ────────────────────────────────────
# See AlertsButton in the UI for setup instructions.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
ALERT_PRICE_PCT=5.0

# ── App ───────────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins.
# In production: set to your Vercel URL, e.g. https://rocket-news.vercel.app
CORS_ORIGINS=http://localhost:3000
