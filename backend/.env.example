# Copy to .env and fill in values

# ── Market Data ──────────────────────────────────────────────────
# Finnhub (free tier: 60 req/min, WebSocket real-time)
FINNHUB_API_KEY=your_finnhub_key_here

# Polygon.io (paid, for production real-time)
# POLYGON_API_KEY=your_polygon_key_here

# ── Social / Sentiment ───────────────────────────────────────────
# Reddit (public API, no key needed for read-only — uses user-agent)
REDDIT_USER_AGENT=RocketNews/0.1

# X/Twitter API (optional — skip for v1, use Reddit instead)
# X_BEARER_TOKEN=your_x_bearer_token_here

# ── AI (Airlock + Chat fallback) ─────────────────────────────────
# Backend uses this for the airlock scoring pipeline only.
# Chat calls use the user's key sent from the frontend.
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── App ───────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
